# ============================================================================
# CB Suplementos — Variáveis de Ambiente
# ============================================================================
# Copie para `.env` e preencha. NUNCA commite .env no Git.
# ============================================================================

# ----------------------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL — Railway)
# ----------------------------------------------------------------------------
# Railway > plugin PostgreSQL > Variables > copie "DATABASE_URL"
DATABASE_URL="postgresql://postgres:wRvbwyJCdrPRrnxAqCJHJWIdydsliAtz@thomas.proxy.rlwy.net:54886/railway"

# ----------------------------------------------------------------------------
# ADMIN INICIAL (usado apenas no seed)
# ----------------------------------------------------------------------------
ADMIN_EMAIL="admin@cbsuplementos.com.br"
ADMIN_PASSWORD="TrocarNoPrimeiroLogin@2026"

# ----------------------------------------------------------------------------
# AUTH — NextAuth v5
# ----------------------------------------------------------------------------
# Gere com: openssl rand -base64 32
# Windows: https://generate-secret.vercel.app/32
AUTH_SECRET="gere-um-secret-forte-aqui"
NEXTAUTH_SECRET="mesmo-valor-do-AUTH_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# CLOUDINARY — Upload e CDN de imagens
# ----------------------------------------------------------------------------
# Crie conta grátis em https://cloudinary.com
# Dashboard > Account Details > copie os 3 valores
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="abcdefghijklmnopqrstuvwx"

# ----------------------------------------------------------------------------
# MERCADO PAGO — Pagamento (Pix + Cartão)
# ----------------------------------------------------------------------------
# https://www.mercadopago.com.br/developers > Suas integrações > Credenciais
# Use as credenciais de TESTE primeiro, depois troque pelas de PRODUÇÃO
MP_ACCESS_TOKEN="APP_USR-xxxx-xxxx-xxxx"
MP_PUBLIC_KEY="APP_USR-xxxx-xxxx-xxxx"

# ----------------------------------------------------------------------------
# MELHOR ENVIO — Cálculo de frete real
# ----------------------------------------------------------------------------
# https://melhorenvio.com.br > Área do Desenvolvedor > Token
# ME_SANDBOX=true usa o ambiente de testes (sem custo)
MELHOR_ENVIO_TOKEN="seu-token-aqui"
ME_SANDBOX="true"

# ----------------------------------------------------------------------------
# SITE — URL pública
# ----------------------------------------------------------------------------
# Em dev: http://localhost:3000
# Em produção: o domínio gerado pelo Railway
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
